{
    "manifest_version": 3,
    "name": "Children Footprint Tracker",
    "version": "1.0",
    "description": "Track account registrations for parents.",
    "permissions": [
        "activeTab",
        "storage",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    }
  }